rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'category', 'description', 'image']) &&
             data.id is string && data.id.size() <= 64 &&
             data.name is string && data.name.size() <= 200 &&
             data.category is string && data.category.size() <= 100 &&
             data.description is string && data.description.size() <= 1000 &&
             data.image is string && data.image.size() <= 1000;
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidProduct(request.resource.data);
      allow update: if isSignedIn() && isValidProduct(request.resource.data);
      allow delete: if isSignedIn();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
