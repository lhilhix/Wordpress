rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isAdmin() { 
      return isSignedIn() && request.auth.token.email == 'davidmbueso@gmail.com';
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Pillar 2: Validation Blueprints
    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'category', 'industry', 'description', 'image']) &&
             data.id is string && data.id.size() <= 64 &&
             data.name is string && data.name.size() <= 200 &&
             data.category is string && data.category.size() <= 100 &&
             data.industry is string && data.industry.size() <= 100 &&
             data.description is string && data.description.size() <= 2000 &&
             data.image is string && data.image.size() <= 1000 &&
             (!('images' in data) || (data.images is list && data.images.size() <= 20)) &&
             (!('detailedDescription' in data) || (data.detailedDescription is string && data.detailedDescription.size() <= 5000)) &&
             (!('specifications' in data) || (data.specifications is string && data.specifications.size() <= 2000)) &&
             (!('isFeatured' in data) || data.isFeatured is bool) &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidSiteSettings(data) {
      return data.keys().size() <= 30 &&
             (!('chatProvider' in data) || data.chatProvider is string) &&
             (!('chatModel' in data) || data.chatModel is string) &&
             (!('chatApiKey' in data) || data.chatApiKey is string) &&
             (!('chatEndpoint' in data) || data.chatEndpoint is string);
    }

    // 1. Products Collection
    match /products/{productId} {
      // allow read for everyone
      allow read: if true; 
      
      // Restricted write access to admins
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    // 2. Settings Collection
    match /settings/{settingId} {
      // Public read access for site branding
      allow read: if true;
      
      // Restricted write access to admins
      allow write: if isAdmin() && isValidSiteSettings(incoming());
    }

    // 3. Chat Sessions
    function isValidChatMessage(data) {
      return data.keys().hasAll(['role', 'content', 'timestamp']) &&
             data.role in ['user', 'model', 'system'] &&
             data.content is string && data.content.size() <= 4000;
    }

    match /chatSessions/{sessionId} {
      allow read, create, update: if isValidId(sessionId);
      
      match /messages/{messageId} {
        allow read: if isValidId(sessionId);
        allow create: if isValidId(sessionId) && isValidChatMessage(incoming());
      }
    }
  }
}
