rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isAdmin() { 
      return isSignedIn() && 
             (request.auth.token.email == 'davidmbueso@gmail.com' && request.auth.token.email_verified == true);
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Pillar 2: Validation Blueprints
    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'category', 'description', 'image']) &&
             data.id is string && data.id.size() <= 64 &&
             data.name is string && data.name.size() <= 200 &&
             data.category is string && data.category.size() <= 100 &&
             data.description is string && data.description.size() <= 2000 &&
             data.image is string && data.image.size() <= 1000;
    }

    function isValidSiteSettings(data) {
      return data.keys().size() <= 15; // Loose check for simple settings object
    }

    // 1. Products Collection
    match /products/{productId} {
      // Pillar 3: Path Variable Hardening
      // allow get: if isValidId(productId); // Hardening on single document target
      
      // Pillar 8: Secure List Queries
      // Public read access for the catalog
      allow read: if true; 
      
      // Restricted write access to admins
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    // 2. Settings Collection
    match /settings/{settingId} {
      // Public read access for site branding
      allow read: if true;
      
      // Restricted write access to admins
      allow write: if isAdmin() && isValidSiteSettings(incoming());
    }
  }
}
